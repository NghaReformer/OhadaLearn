SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Feedback widget — optional
# Set to "false" to hide the "Beta" badge on the feedback launcher in production.
PUBLIC_SHOW_FEEDBACK_BADGE=true
# Optional: git SHA or build identifier echoed back in feedback reports for debugging.
PUBLIC_BUILD_SHA=
